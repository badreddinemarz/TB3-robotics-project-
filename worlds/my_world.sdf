        <visual name="v"><geometry><box><size>0.20 10.3 1.50</size></box></geometry>
          <material><ambient>0.55 0.45 0.35 1</ambient><diffuse>0.55 0.45 0.35 1</diffuse></material>
        </visual>
      </link>
    </model>
    

    <!-- ═══ ZONE 4 — x=12/13 — Orange barrel slalom ═══ -->
    <model name="Z4_barrel_a"><static>true</static><pose>12.0 0.75 0.350 0 0 0</pose>
      <link name="link">
        <collision name="c"><geometry><cylinder><radius>0.24</radius><length>0.70</length></cylinder></geometry></collision>
        <visual name="v"><geometry><cylinder><radius>0.24</radius><length>0.70</length></cylinder></geometry>
          <material><ambient>0.92 0.55 0.02 1</ambient><diffuse>0.92 0.55 0.02 1</diffuse></material>
        </visual>
      </link>
    </model>
   

   

  </world>
</sdf>